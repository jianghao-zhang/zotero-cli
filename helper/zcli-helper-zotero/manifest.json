{
  "manifest_version": 2,
  "name": "zcli Helper for Zotero",
  "version": "0.1.0",
  "description": "Optional local Zotero runtime bridge for zcli dry-run-first mutations.",
  "homepage_url": "https://github.com/jianghao-zhang/zotero-cli",
  "author": "zotero-cli contributors",
  "applications": {
    "zotero": {
      "id": "zcli-helper@zotero-cli.local",
      "update_url": "https://raw.githubusercontent.com/jianghao-zhang/zotero-cli/main/helper/zcli-helper-zotero/updates.json",
      "strict_min_version": "6.999",
      "strict_max_version": "9.*"
    }
  }
}
